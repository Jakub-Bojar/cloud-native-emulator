    },
    {
      "app_id": "app_store_b",
      "app": { "app_name": "store_b", "app_type": "sink", "deployment_ref": "deployment_store_b" },
      "load": { "cpu": { "a": 1, "b": 70 }, "ram": { "a": 0.4, "b": 90 }, "net": { "a": 0, "b": 0 } }
    }
