    { "deployment_id": "deployment_proc_a",   "deployment_name": "processor-a",  "namespace": "x-demo", "replicas": 1, "node_selector": { "topology.tier_id": "tier_1" } },
    { "deployment_id": "deployment_store_a",  "deployment_name": "store-a",      "namespace": "x-demo", "replicas": 1, "node_selector": { "topology.tier_id": "tier_1" } },
    { "deployment_id": "deployment_ingest_b", "deployment_name": "ingest-b",     "namespace": "x-demo", "replicas": 1, "node_selector": { "topology.tier_id": "tier_1" } },
    { "deployment_id": "deployment_store_b",  "deployment_name": "store-b",      "namespace": "x-demo", "replicas": 1, "node_selector": { "topology.tier_id": "tier_1" } }
