    },
    {
      "app_id": "app_proc_a",
      "app": { "app_name": "processor_a", "app_type": "compute", "deployment_ref": "deployment_proc_a" },
      "load": { "cpu": { "a": 3, "b": 80 }, "ram": { "a": 0.3, "b": 60 }, "net": { "a": 0.3, "b": 2 } }
    },
    {
      "app_id": "app_store_a",
      "app": { "app_name": "store_a", "app_type": "sink", "deployment_ref": "deployment_store_a" },
      "load": { "cpu": { "a": 1, "b": 70 }, "ram": { "a": 0.4, "b": 90 }, "net": { "a": 0, "b": 0 } }
    },
    {
      "app_id": "app_ingest_b",
      "app": { "app_name": "ingest_b", "app_type": "source", "deployment_ref": "deployment_ingest_b" },
