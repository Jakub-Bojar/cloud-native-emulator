{
  "uid": "emulator-peer-rtt",
  "title": "Emulator — Latency",
  "description": "Inter-tier latency: measured (worker_peer_rtt_ms — one TCP handshake from each worker to each peer every 15s, pod-to-pod so it captures the injected Chaos Mesh delay) vs configured (emulator_configured_rtt_ms — what the template's latency field asks for, served by the controller). Measured should track configured plus jitter under load.",
  "tags": ["emulator", "latency"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-30m", "to": "now" },
  "schemaVersion": 39,
  "version": 4,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource",
        "hide": 0,
        "current": {},
        "options": [],
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Pod → peer RTT",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "worker_peer_rtt_ms",
          "legendFormat": "{{pod}} → {{peer}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Current RTT floor per pod → node (min over 5m — closest to the injected latency)",
      "description": "Measured floor from each worker pod to the NODE its peers run on. The peer IP from worker_peer_rtt_ms is mapped to a node by joining kube_pod_info on the IP; a pod talking to several peers on the same node is collapsed to one figure (min).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "decimals": 1 },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "min by (pod, node) (min_over_time(worker_peer_rtt_ms[5m]) * on(peer) group_left(node) label_replace(kube_pod_info{namespace=\"cloud-native-emulator\"}, \"peer\", \"$1\", \"pod_ip\", \"(.+)\"))",
          "legendFormat": "{{pod}} → {{node}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Latency between nodes (configured)",
      "description": "What the latency is MEANT to be between each pair of nodes, from the template's latency field. One figure per node pair; changes the moment you PATCH a latency value.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 22 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "value",
        "justifyMode": "center",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "emulator_configured_rtt_ms",
          "legendFormat": "{{pair}}",
          "instant": true
        }
      ]
    }
  ]
}
