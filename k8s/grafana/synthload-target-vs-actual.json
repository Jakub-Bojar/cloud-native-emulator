{
  "title": "Synthetic Load — Target vs Actual",
  "uid": "synthload-target-vs-actual-v2",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "tags": ["synthload", "cloud-native-emulator"],
  "templating": {
    "list": [
      {
        "name": "pod",
        "type": "constant",
        "current": { "text": "load", "value": "load", "selected": true },
        "query": "load",
        "hide": 2
      },
      {
        "name": "container",
        "type": "constant",
        "current": { "text": "load", "value": "load", "selected": true },
        "query": "load",
        "hide": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "CPU",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "stat",
      "title": "CPU target (% of 1 core)",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "blue" } },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "targets": [
        { "refId": "A", "expr": "synthload_cpu_target_pct{pod=~\"$pod\"}" }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "CPU actual (cAdvisor, % of 1 core)",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "green" } },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(container_cpu_usage_seconds_total{pod=~\"$pod\",container=~\"$container\",service=\"kps-kube-prometheus-stack-kubelet\"}[2m])) * 100" }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "CPU delta (actual − target)",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": -10 },
              { "color": "green", "value": -3 },
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(container_cpu_usage_seconds_total{pod=~\"$pod\",container=~\"$container\",service=\"kps-kube-prometheus-stack-kubelet\"}[2m])) * 100) - max(synthload_cpu_target_pct{pod=~\"$pod\"})"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "CPU accuracy",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - abs((sum(rate(container_cpu_usage_seconds_total{pod=~\"$pod\",container=~\"$container\",service=\"kps-kube-prometheus-stack-kubelet\"}[2m])) * 100) - max(synthload_cpu_target_pct{pod=~\"$pod\"})) / max(synthload_cpu_target_pct{pod=~\"$pod\"}))"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "CPU — target vs actual (% of one core)",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "target" }, "properties": [{ "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "actual (cAdvisor)" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "app self-measured" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }, { "id": "custom.fillOpacity", "value": 0 }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "synthload_cpu_target_pct{pod=~\"$pod\"}", "legendFormat": "target" },
        { "refId": "B", "expr": "sum(rate(container_cpu_usage_seconds_total{pod=~\"$pod\",container=~\"$container\",service=\"kps-kube-prometheus-stack-kubelet\"}[2m])) * 100", "legendFormat": "actual (cAdvisor)" },
        { "refId": "C", "expr": "synthload_cpu_measured_pct{pod=~\"$pod\"}", "legendFormat": "app self-measured" }
      ]
    },
    {
      "id": 2,
      "type": "row",
      "title": "Memory",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 20,
      "type": "stat",
      "title": "RAM target",
      "gridPos": { "x": 0, "y": 14, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "blue" } },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "targets": [
        { "refId": "A", "expr": "synthload_ram_target_bytes{pod=~\"$pod\"}" }
      ]
    },
    {
      "id": 21,
      "type": "stat",
      "title": "RAM actual (cAdvisor working set)",
      "gridPos": { "x": 6, "y": 14, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "green" } },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" },
      "targets": [
        { "refId": "A", "expr": "max(container_memory_working_set_bytes{pod=~\"$pod\",container=~\"$container\",service=\"kps-kube-prometheus-stack-kubelet\"})" }
      ]
    },
    {
      "id": 22,
      "type": "stat",
      "title": "RAM delta (actual − target)",
      "gridPos": { "x": 12, "y": 14, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": -52428800 },
              { "color": "green", "value": -10485760 },
              { "color": "green", "value": 10485760 },
              { "color": "orange", "value": 52428800 },
              { "color": "red", "value": 104857600 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(container_memory_working_set_bytes{pod=~\"$pod\",container=~\"$container\",service=\"kps-kube-prometheus-stack-kubelet\"}) - max(synthload_ram_target_bytes{pod=~\"$pod\"})"
        }
      ]
    },
    {
      "id": 23,
      "type": "stat",
      "title": "RAM accuracy",
      "gridPos": { "x": 18, "y": 14, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - abs(max(container_memory_working_set_bytes{pod=~\"$pod\",container=~\"$container\",service=\"kps-kube-prometheus-stack-kubelet\"}) - max(synthload_ram_target_bytes{pod=~\"$pod\"})) / max(synthload_ram_target_bytes{pod=~\"$pod\"}))"
        }
      ]
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Memory — target vs actual (bytes)",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "target" }, "properties": [{ "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "actual (working set)" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "app RSS" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }, { "id": "custom.fillOpacity", "value": 0 }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "synthload_ram_target_bytes{pod=~\"$pod\"}", "legendFormat": "target" },
        { "refId": "B", "expr": "max(container_memory_working_set_bytes{pod=~\"$pod\",container=~\"$container\",service=\"kps-kube-prometheus-stack-kubelet\"})", "legendFormat": "actual (working set)" },
        { "refId": "C", "expr": "synthload_ram_rss_bytes{pod=~\"$pod\"}", "legendFormat": "app RSS" }
      ]
    },
    {
      "id": 3,
      "type": "row",
      "title": "Network (egress)",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 30,
      "type": "stat",
      "title": "Net target (Mbps)",
      "gridPos": { "x": 0, "y": 27, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "Mbits", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "blue" } },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "targets": [
        { "refId": "A", "expr": "synthload_net_target_mbps{pod=~\"$pod\"}" }
      ]
    },
    {
      "id": 31,
      "type": "stat",
      "title": "Net actual (cAdvisor TX, Mbps)",
      "gridPos": { "x": 6, "y": 27, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "Mbits", "decimals": 2, "color": { "mode": "fixed", "fixedColor": "green" } },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(container_network_transmit_bytes_total{pod=~\"$pod\",interface=\"eth0\",service=\"kps-kube-prometheus-stack-kubelet\"}[2m])) * 8 / 1000000" }
      ]
    },
    {
      "id": 32,
      "type": "stat",
      "title": "Net delta (actual − target, Mbps)",
      "gridPos": { "x": 12, "y": 27, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbits",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": -2 },
              { "color": "green", "value": -0.5 },
              { "color": "green", "value": 0.5 },
              { "color": "orange", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(container_network_transmit_bytes_total{pod=~\"$pod\",interface=\"eth0\",service=\"kps-kube-prometheus-stack-kubelet\"}[2m])) * 8 / 1000000) - max(synthload_net_target_mbps{pod=~\"$pod\"})"
        }
      ]
    },
    {
      "id": 33,
      "type": "stat",
      "title": "Net accuracy",
      "gridPos": { "x": 18, "y": 27, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - abs((sum(rate(container_network_transmit_bytes_total{pod=~\"$pod\",interface=\"eth0\",service=\"kps-kube-prometheus-stack-kubelet\"}[2m])) * 8 / 1000000) - max(synthload_net_target_mbps{pod=~\"$pod\"})) / max(synthload_net_target_mbps{pod=~\"$pod\"}))"
        }
      ]
    },
    {
      "id": 34,
      "type": "timeseries",
      "title": "Network — target vs actual TX (Mbps)",
      "gridPos": { "x": 0, "y": 31, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "Mbits", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "target" }, "properties": [{ "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "actual TX (cAdvisor)" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "app-reported TX" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }, { "id": "custom.fillOpacity", "value": 0 }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "synthload_net_target_mbps{pod=~\"$pod\"}", "legendFormat": "target" },
        { "refId": "B", "expr": "sum(rate(container_network_transmit_bytes_total{pod=~\"$pod\",interface=\"eth0\",service=\"kps-kube-prometheus-stack-kubelet\"}[2m])) * 8 / 1000000", "legendFormat": "actual TX (cAdvisor)" },
        { "refId": "C", "expr": "rate(synthload_net_sent_bytes_total{pod=~\"$pod\"}[2m]) * 8 / 1000000", "legendFormat": "app-reported TX" }
      ]
    },
    {
      "id": 35,
      "type": "timeseries",
      "title": "Network send errors/sec",
      "gridPos": { "x": 0, "y": 39, "w": 24, "h": 6 },
      "fieldConfig": {
        "defaults": { "unit": "none", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [
        { "refId": "A", "expr": "rate(synthload_net_send_errors_total{pod=~\"$pod\"}[2m])", "legendFormat": "errors/s" }
      ]
    }
  ]
}
